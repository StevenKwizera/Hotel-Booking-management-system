# Gmail — REAL emails (App Password, NOT your normal Gmail password)
# 1. Google Account → Security → 2-Step Verification ON
# 2. App passwords → create "Orkestra" → copy 16-character password
# 3. Paste below (no spaces). MAIL_FROM must match MAIL_USERNAME.
# https://support.google.com/accounts/answer/185833
# Set FRONTEND_URL to match your Vite dev server (5173 or 5174).
FRONTEND_URL=http://localhost:5173

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here
MAIL_FROM=your.email@gmail.com

ORKESTRA_ADMIN_EMAIL=stevegatanazi@gmail.com
ORKESTRA_ADMIN_NAME=Steve Gatanazi
ORKESTRA_ADMIN_PASSWORD=Orkestra@2026

# Paypack mobile money (https://docs.paypack.rw)
PAYPACK_BASE_URL=https://payments.paypack.rw/api
PAYPACK_CLIENT_ID=3722a218-5eb8-11f1-97b7-deadd43720af
PAYPACK_CLIENT_SECRET=your-paypack-client-secret-here
PAYPACK_WEBHOOK_MODE=production
PAYPACK_WEBHOOK_SECRET=
PAYPACK_SIMULATE_WHEN_UNCONFIGURED=false
PAYPACK_USE_TEST_AMOUNT=false
PAYPACK_TEST_AMOUNT_RWF=5
